# CUA-World visualizer — large regenerable artifacts.
# Caches: rebuilt by re-running the pipeline (enrich is expensive though).
extras/visualization/cua_world/visualizer/data/cache/
# Intermediate pipeline outputs (regenerated by `compile` from the cache).
extras/visualization/cua_world/visualizer/data/raw_tasks.jsonl
extras/visualization/cua_world/visualizer/data/tasks_with_gdp.jsonl
extras/visualization/cua_world/visualizer/data/tasks_enriched.jsonl
extras/visualization/cua_world/visualizer/data/skipped.jsonl
# 3072-dim OpenAI embeddings (server-mode only; static site uses bge instead).
extras/visualization/cua_world/visualizer/data/embeddings.f16.npy
extras/visualization/cua_world/visualizer/data/embedding_ids.json
# Built bge matrix + final index — re-emitted by `compile`. The shipped
# copies live at website/explore/data/ and are tracked.
extras/visualization/cua_world/visualizer/data/embeddings_bge.f16.bin
extras/visualization/cua_world/visualizer/data/embedding_ids_bge.json
extras/visualization/cua_world/visualizer/data/index.json
