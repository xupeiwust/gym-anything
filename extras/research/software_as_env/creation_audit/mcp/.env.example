# Pick ONE provider and set the matching key. Copy this file to .env;
# do NOT commit .env.

SCREENSHOT_QUERY_PROVIDER=gemini
SCREENSHOT_QUERY_MODEL=gemini-3-flash-preview

# --- Gemini (provider=gemini) ---
GEMINI_API_KEY=

# --- Databricks-hosted Claude (provider=databricks) ---
# DATABRICKS_TOKEN=
# SCREENSHOT_QUERY_BASE_URL=https://<workspace>.cloud.databricks.com/serving-endpoints

# --- OpenAI / OpenAI-compatible endpoint (provider=openai) ---
# OPENAI_API_KEY=
# SCREENSHOT_QUERY_BASE_URL=https://api.openai.com/v1
