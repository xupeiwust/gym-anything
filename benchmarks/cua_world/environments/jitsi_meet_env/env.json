{
  "id": "jitsi_meet_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Jitsi Meet video conferencing environment for testing meeting creation, moderation, and collaboration features",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "vnc": {
    "password": "password"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/jitsi_meet_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/jitsi_meet_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/jitsi_meet_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/jitsi_meet_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_jitsi.sh",
    "post_start": "/workspace/scripts/setup_jitsi.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input",
          "docker"
        ],
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "tags": [
    "linux",
    "jitsi",
    "video-conferencing",
    "web-application",
    "docker",
    "webrtc"
  ],
  "default_cache_level": "post_start"
}
