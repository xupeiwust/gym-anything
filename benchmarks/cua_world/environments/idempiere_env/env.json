{
  "id": "idempiere_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "iDempiere 12 open-source ERP/CRM environment with GardenWorld demo data for testing enterprise business workflows including sales orders, purchase orders, business partner management, product catalog, and financial journal entries.",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "vnc": {
    "password": "password"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/idempiere_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/idempiere_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/idempiere_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_idempiere.sh",
    "post_start": "/workspace/scripts/setup_idempiere.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "default_cache_level": "post_start"
}
