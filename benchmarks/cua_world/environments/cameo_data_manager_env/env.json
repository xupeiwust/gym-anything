{
  "id": "cameo_data_manager_env@0.1",
  "version": "0.1",
  "base": "windows-11",
  "os_type": "windows",
  "description": "CAMEO Data Manager environment for hazardous chemical emergency planning and Tier II data management",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1280,
        720
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": false,
  "step_cycle_ms": 200,
  "vnc": {
    "enable": true,
    "host_port": -1,
    "password": "password",
    "view_only": false
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/cameo_data_manager_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/cameo_data_manager_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/cameo_data_manager_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\install_cameo.ps1",
    "post_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\setup_cameo.ps1"
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "role": "developer",
      "permissions": {
        "sudo": true,
        "groups": [
          "Administrators"
        ]
      }
    }
  ],
  "default_cache_level": "post_start",
  "default_use_savevm": true
}
