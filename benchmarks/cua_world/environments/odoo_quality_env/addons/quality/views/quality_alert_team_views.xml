<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quality Alert Team List View -->
    <record id="quality_alert_team_view_list" model="ir.ui.view">
        <field name="name">quality.alert.team.list</field>
        <field name="model">quality.alert.team</field>
        <field name="arch" type="xml">
            <tree string="Quality Teams">
                <field name="name"/>
                <field name="member_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <!-- Quality Alert Team Form View -->
    <record id="quality_alert_team_view_form" model="ir.ui.view">
        <field name="name">quality.alert.team.form</field>
        <field name="model">quality.alert.team</field>
        <field name="arch" type="xml">
            <form string="Quality Team">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Team Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Assembly QA Team"/>
                        </h1>
                    </div>
                    <group>
                        <field name="member_ids" widget="many2many_tags" placeholder="Add team members..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Quality Alert Team Action -->
    <record id="action_quality_alert_team" model="ir.actions.act_window">
        <field name="name">Quality Teams</field>
        <field name="res_model">quality.alert.team</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first quality team
            </p>
            <p>
                Organize your quality personnel into teams to manage alerts and inspections.
            </p>
        </field>
    </record>
</odoo>
