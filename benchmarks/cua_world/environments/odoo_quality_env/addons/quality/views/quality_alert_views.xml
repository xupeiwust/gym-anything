<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quality Alert Stage List View (for configuration) -->
    <record id="quality_alert_stage_view_list" model="ir.ui.view">
        <field name="name">quality.alert.stage.list</field>
        <field name="model">quality.alert.stage</field>
        <field name="arch" type="xml">
            <tree string="Alert Stages" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="done"/>
                <field name="folded"/>
            </tree>
        </field>
    </record>

    <!-- Quality Alert List View -->
    <record id="quality_alert_view_list" model="ir.ui.view">
        <field name="name">quality.alert.list</field>
        <field name="model">quality.alert</field>
        <field name="arch" type="xml">
            <tree string="Quality Alerts" decoration-muted="stage_id.done == True">
                <field name="priority" widget="priority" optional="show"/>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="product_id" optional="show"/>
                <field name="team_id" optional="show"/>
                <field name="user_id" optional="show" widget="many2one_avatar_user"/>
                <field name="date" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- Quality Alert Kanban View -->
    <record id="quality_alert_view_kanban" model="ir.ui.view">
        <field name="name">quality.alert.kanban</field>
        <field name="model">quality.alert</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column">
                <field name="stage_id"/>
                <field name="priority"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click oe_kanban_color_#{kanban_getcolor(record.color.raw_value)}">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_body">
                                        <field name="priority" widget="priority"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="product_id"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="team_id"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Quality Alert Form View -->
    <record id="quality_alert_view_form" model="ir.ui.view">
        <field name="name">quality.alert.form</field>
        <field name="model">quality.alert</field>
        <field name="arch" type="xml">
            <form string="Quality Alert">
                <header>
                    <field name="stage_id" widget="statusbar" clickable="1"
                           options="{'fold_field': 'folded'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Alert title..."/>
                        </h1>
                        <field name="priority" widget="priority"/>
                    </div>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="team_id"/>
                        </group>
                        <group>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="partner_id"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the quality issue..."/>
                        </page>
                        <page string="Corrective Action" name="corrective">
                            <field name="corrective_action" placeholder="Describe the corrective action taken..."/>
                        </page>
                        <page string="Preventive Action" name="preventive">
                            <field name="preventive_action" placeholder="Describe preventive measures to avoid recurrence..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Quality Alert Action -->
    <record id="action_quality_alert" model="ir.actions.act_window">
        <field name="name">Quality Alerts</field>
        <field name="res_model">quality.alert</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No quality alerts found
            </p>
            <p>
                Quality alerts notify the quality team of product issues detected during production or delivery.
            </p>
        </field>
    </record>
</odoo>
