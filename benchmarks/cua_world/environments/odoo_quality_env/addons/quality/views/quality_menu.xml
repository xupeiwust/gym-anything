<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Root Quality Menu -->
    <menuitem id="quality_menu_root"
              name="Quality"
              sequence="200"
              web_icon="quality,static/description/icon.png"/>

    <!-- Quality Alerts Menu -->
    <menuitem id="quality_menu_alerts"
              name="Quality Alerts"
              parent="quality_menu_root"
              action="action_quality_alert"
              sequence="10"/>

    <!-- Quality Control Points Menu -->
    <menuitem id="quality_menu_points"
              name="Control Points"
              parent="quality_menu_root"
              action="action_quality_point"
              sequence="20"/>

    <!-- Quality Checks Menu -->
    <menuitem id="quality_menu_checks"
              name="Quality Checks"
              parent="quality_menu_root"
              action="action_quality_check_tree"
              sequence="30"/>

    <!-- Configuration Sub-menu -->
    <menuitem id="quality_menu_configuration"
              name="Configuration"
              parent="quality_menu_root"
              sequence="100"/>

    <menuitem id="quality_menu_teams"
              name="Quality Teams"
              parent="quality_menu_configuration"
              action="action_quality_alert_team"
              sequence="10"/>

    <!-- Alert Stages Action (must be defined before menuitem reference) -->
    <record id="action_quality_alert_stage" model="ir.actions.act_window">
        <field name="name">Alert Stages</field>
        <field name="res_model">quality.alert.stage</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="quality_menu_stages"
              name="Alert Stages"
              parent="quality_menu_configuration"
              action="action_quality_alert_stage"
              sequence="20"/>
</odoo>
