<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quality Check List View -->
    <record id="quality_check_view_list" model="ir.ui.view">
        <field name="name">quality.check.list</field>
        <field name="model">quality.check</field>
        <field name="arch" type="xml">
            <tree string="Quality Checks"
                  decoration-success="quality_state == 'pass'"
                  decoration-danger="quality_state == 'fail'"
                  decoration-muted="quality_state == 'none'">
                <field name="name"/>
                <field name="quality_state" widget="badge"
                       decoration-success="quality_state == 'pass'"
                       decoration-danger="quality_state == 'fail'"
                       decoration-warning="quality_state == 'none'"/>
                <field name="point_id" optional="show"/>
                <field name="product_id" optional="show"/>
                <field name="team_id" optional="show"/>
                <field name="user_id" widget="many2one_avatar_user" optional="show"/>
                <field name="date" optional="show"/>
                <button name="do_pass" string="Pass" type="object"
                        class="btn-success"
                        invisible="quality_state == 'pass'"/>
                <button name="do_fail" string="Fail" type="object"
                        class="btn-danger"
                        invisible="quality_state == 'fail'"/>
            </tree>
        </field>
    </record>

    <!-- Quality Check Form View -->
    <record id="quality_check_view_form" model="ir.ui.view">
        <field name="name">quality.check.form</field>
        <field name="model">quality.check</field>
        <field name="arch" type="xml">
            <form string="Quality Check">
                <header>
                    <button name="do_pass" string="Pass" type="object"
                            class="btn-primary oe_highlight"
                            invisible="quality_state == 'pass'"/>
                    <button name="do_fail" string="Fail" type="object"
                            class="btn-danger"
                            invisible="quality_state == 'fail'"/>
                    <field name="quality_state" widget="statusbar"
                           statusbar_visible="none,pass,fail"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Quality check name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="point_id"/>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                        </group>
                        <group>
                            <field name="team_id"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Add inspection notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Quality Check Action (tree view) -->
    <record id="action_quality_check_tree" model="ir.actions.act_window">
        <field name="name">Quality Checks</field>
        <field name="res_model">quality.check</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No quality checks found
            </p>
            <p>
                Quality checks are created when products reach quality control points during operations.
            </p>
        </field>
    </record>
</odoo>
