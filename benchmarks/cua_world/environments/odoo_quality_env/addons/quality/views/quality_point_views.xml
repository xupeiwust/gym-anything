<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quality Control Point List View -->
    <record id="quality_point_view_list" model="ir.ui.view">
        <field name="name">quality.point.list</field>
        <field name="model">quality.point</field>
        <field name="arch" type="xml">
            <tree string="Quality Control Points">
                <field name="name"/>
                <field name="test_type"/>
                <field name="product_ids" widget="many2many_tags" optional="show"/>
                <field name="picking_type_ids" widget="many2many_tags" optional="show"/>
                <field name="team_id" optional="show"/>
                <field name="check_count" string="Checks"/>
            </tree>
        </field>
    </record>

    <!-- Quality Control Point Form View -->
    <record id="quality_point_view_form" model="ir.ui.view">
        <field name="name">quality.point.form</field>
        <field name="model">quality.point</field>
        <field name="arch" type="xml">
            <form string="Quality Control Point">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Control point title..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="test_type"/>
                            <field name="team_id"/>
                        </group>
                        <group string="Applicability">
                            <field name="product_ids" widget="many2many_tags"/>
                            <field name="product_tmpl_ids" widget="many2many_tags"/>
                            <field name="picking_type_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Instructions" name="instructions">
                            <field name="note" placeholder="Describe the inspection procedure..."/>
                        </page>
                        <page string="Failure Message" name="failure">
                            <field name="failure_message" placeholder="Message to display when check fails..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Quality Control Point Action -->
    <record id="action_quality_point" model="ir.actions.act_window">
        <field name="name">Quality Control Points</field>
        <field name="res_model">quality.point</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first quality control point
            </p>
            <p>
                Quality control points define where and how quality checks are performed on products.
            </p>
        </field>
    </record>
</odoo>
