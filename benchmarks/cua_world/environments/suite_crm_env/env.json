{
  "id": "suite_crm_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "SuiteCRM open-source CRM environment for testing sales pipeline, customer support, and relationship management workflows",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "vnc": {
    "password": "password"
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/suite_crm_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/suite_crm_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/suite_crm_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/suite_crm_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/suite_crm_env/utils",
      "target": "/workspace/utils",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_suitecrm.sh",
    "post_start": "/workspace/scripts/setup_suitecrm.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "default_cache_level": "post_start"
}
