{
  "id": "geo_server_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "GeoServer geospatial data server environment with PostGIS backend and Natural Earth data for publishing, styling, and managing geospatial layers via the web admin interface",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "security": {
    "user": "root",
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/geo_server_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/geo_server_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/geo_server_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/geo_server_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_geoserver.sh",
    "post_start": "/workspace/scripts/setup_geoserver.sh"
  },
  "vnc": {
    "enable": false,
    "password": "password"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input",
          "docker"
        ],
        "env_vars": {
          "DISPLAY": ":1",
          "GEOSERVER_URL": "http://localhost:8080/geoserver",
          "GEOSERVER_USER": "admin",
          "GEOSERVER_PASS": "Admin123!"
        }
      }
    }
  ],
  "default_cache_level": "post_start"
}
