{
  "id": "orangehrm_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "OrangeHRM 5.8 Human Resource Management System environment for HR workflow tasks",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/orangehrm_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/orangehrm_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/orangehrm_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_orangehrm.sh",
    "post_start": "/workspace/scripts/setup_orangehrm.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "vnc": {
    "password": "password"
  },
  "default_cache_level": "post_start"
}
