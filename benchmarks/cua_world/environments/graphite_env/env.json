{
  "id": "graphite_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Graphite monitoring environment for time-series data visualization. Provides a fully configured Graphite instance (graphite-web, carbon, whisper) with real system metrics collected via collectd, accessible through a Firefox browser.",
  "tags": [
    "web-application",
    "monitoring",
    "time-series",
    "graphite",
    "metrics"
  ],
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "resolution": [
        1920,
        1080
      ],
      "fps": 10,
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/cua_world/environments/graphite_env/artifacts",
    "video_fps": 10,
    "video_resolution": [
      1920,
      1080
    ]
  },
  "vnc": {
    "enable": false,
    "host_port": 5969,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/graphite_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/graphite_env/config",
      "target": "/workspace/config",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/graphite_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/graphite_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_graphite.sh",
    "post_start": "/workspace/scripts/setup_graphite.sh"
  },
  "user_accounts": [
    {
      "name": "ga",
      "password": "password123",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "sudo",
          "audio",
          "video",
          "input"
        ],
        "env_vars": {
          "DISPLAY": ":1"
        }
      }
    }
  ],
  "default_cache_level": "post_start"
}
