{
  "id": "copper_point_of_sale_env@0.1",
  "version": "0.1",
  "base": "windows-11",
  "os_type": "windows",
  "description": "Windows 11 environment with NCH Copper Point of Sale Software for retail POS tasks including inventory management, sales processing, customer management, receipt configuration, and sales reporting with real retail product data",
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1280,
        720
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": false,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/copper_point_of_sale_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "password": "password",
    "view_only": false
  },
  "security": {
    "user": "root",
    "privileged": true
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 6,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/copper_point_of_sale_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/copper_point_of_sale_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/copper_point_of_sale_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\install_copper.ps1",
    "post_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\setup_copper.ps1"
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "role": "developer",
      "note": "Default dockur/windows user",
      "permissions": {
        "sudo": true,
        "groups": [
          "Administrators"
        ],
        "shell": "powershell"
      }
    }
  ],
  "tags": [
    "windows",
    "windows-11",
    "copper",
    "pos",
    "point-of-sale",
    "retail",
    "inventory",
    "sales",
    "nch-software",
    "desktop"
  ],
  "default_cache_level": "post_start",
  "default_use_savevm": true
}
