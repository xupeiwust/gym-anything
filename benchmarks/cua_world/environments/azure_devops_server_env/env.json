{
  "id": "azure_devops_server_env@0.1",
  "version": "0.1",
  "base": "windows-11",
  "os_type": "windows",
  "description": "Windows 11 environment with Azure DevOps Server 2022 Express for project management, work item tracking, Git repositories, and sprint board tasks using realistic software development data",
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1280,
        720
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": false,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/azure_devops_server_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "password": "password",
    "view_only": false
  },
  "security": {
    "user": "root",
    "privileged": true
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 10,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/azure_devops_server_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/azure_devops_server_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/azure_devops_server_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\install_azure_devops.ps1",
    "post_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\setup_azure_devops.ps1"
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "role": "developer",
      "note": "Default dockur/windows user - becomes Azure DevOps admin",
      "permissions": {
        "sudo": true,
        "groups": [
          "Administrators"
        ],
        "shell": "powershell"
      }
    }
  ],
  "tags": [
    "windows",
    "windows-11",
    "azure-devops",
    "devops",
    "project-management",
    "git",
    "work-items",
    "agile",
    "scrum",
    "web-application"
  ],
  "default_cache_level": "post_start"
}
