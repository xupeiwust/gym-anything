{
  "id": "studio_tax_env@0.1",
  "version": "0.1",
  "base": "windows-11",
  "description": "StudioTax 2024 Canadian personal income tax preparation environment",
  "category": "finance",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1920,
        1080
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 200,
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/studio_tax_env/scripts",
      "target": "C:\\workspace\\scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/studio_tax_env/tasks",
      "target": "C:\\workspace\\tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/studio_tax_env/data",
      "target": "C:\\workspace\\data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\install_studiotax.ps1",
    "post_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\setup_studiotax.ps1"
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "permissions": {
        "sudo": true,
        "sudo_nopasswd": true,
        "groups": [
          "Administrators"
        ],
        "env_vars": {}
      }
    }
  ],
  "default_cache_level": "post_start"
}
