{
  "id": "attendhrm_env@0.1",
  "version": "0.1",
  "base": "windows-11",
  "os_type": "windows",
  "description": "AttendHRM (Lenvica HRMS) environment for HR management tasks including employee management, attendance tracking, leave management, and reporting",
  "category": "hr-management",
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1280,
        720
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": false,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/attendhrm_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "password": "password",
    "view_only": false
  },
  "security": {
    "user": "root",
    "privileged": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/attendhrm_env/scripts",
      "target": "C:\\workspace\\scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/attendhrm_env/data",
      "target": "C:\\workspace\\data",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/attendhrm_env/tasks",
      "target": "C:\\workspace\\tasks",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\install_attendhrm.ps1",
    "post_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\setup_attendhrm.ps1"
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "role": "developer",
      "note": "Default dockur/windows user",
      "permissions": {
        "sudo": true,
        "groups": [
          "Administrators"
        ],
        "shell": "powershell"
      }
    }
  ],
  "tags": [
    "windows",
    "windows-11",
    "hr",
    "hrm",
    "attendance",
    "payroll",
    "desktop",
    "firebird",
    "lenvica"
  ],
  "default_cache_level": "post_start",
  "default_use_savevm": true
}
