{
  "id": "active_inspire_windows_env@0.1",
  "version": "0.1",
  "base": "windows-11",
  "os_type": "windows",
  "description": "Windows 11 environment with ActivInspire (Promethean interactive whiteboard software) for creating educational presentations, annotations, and interactive flipcharts. ActivInspire is used in classrooms worldwide for creating engaging lesson materials with shapes, text, images, and multi-page flipcharts.",
  "category": "education",
  "tags": [
    "windows",
    "windows-11",
    "education",
    "whiteboard",
    "presentation",
    "desktop",
    "activinspire"
  ],
  "licence": "Proprietary (Promethean)",
  "authors": [
    "gym-anything team"
  ],
  "upstream_url": "https://www.prometheanworld.com/products/software/activinspire/",
  "diagnostics": true,
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1280,
        720
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": false,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/active_inspire_windows_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "password": "password",
    "view_only": false
  },
  "security": {
    "user": "root",
    "privileged": true
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 4,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/active_inspire_windows_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/active_inspire_windows_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/active_inspire_windows_env/assets",
      "target": "/workspace/assets",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\install_activinspire.ps1",
    "post_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\setup_activinspire.ps1"
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "role": "teacher",
      "note": "Default dockur/windows user",
      "permissions": {
        "sudo": true,
        "groups": [
          "Administrators"
        ],
        "shell": "powershell"
      }
    }
  ],
  "default_cache_level": "post_start"
}
