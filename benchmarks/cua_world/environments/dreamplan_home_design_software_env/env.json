{
  "id": "dreamplan_home_design_software_env@0.1",
  "version": "0.1",
  "base": "windows-11",
  "os_type": "windows",
  "description": "Windows 11 environment with NCH DreamPlan Home Design Software for architectural design tasks including floor plan editing, furniture placement, material changes, view mode switching, and design export using built-in sample house projects",
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1280,
        720
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": false,
  "step_cycle_ms": 200,
  "recording": {
    "enable": true,
    "output_dir": "benchmarks/cua_world/environments/dreamplan_home_design_software_env/artifacts"
  },
  "vnc": {
    "enable": true,
    "host_port": -1,
    "password": "password",
    "view_only": false
  },
  "security": {
    "user": "root",
    "privileged": true
  },
  "resources": {
    "cpu": 4,
    "mem_gb": 8,
    "gpu": 0,
    "net": true
  },
  "mounts": [
    {
      "source": "benchmarks/cua_world/environments/dreamplan_home_design_software_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/dreamplan_home_design_software_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/cua_world/environments/dreamplan_home_design_software_env/data",
      "target": "/workspace/data",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\install_dreamplan.ps1",
    "post_start": "powershell -ExecutionPolicy Bypass -File C:\\workspace\\scripts\\setup_dreamplan.ps1"
  },
  "user_accounts": [
    {
      "name": "Docker",
      "password": "GymAnything123!",
      "role": "home_designer",
      "note": "Default dockur/windows user",
      "permissions": {
        "sudo": true,
        "groups": [
          "Administrators"
        ],
        "shell": "powershell"
      }
    }
  ],
  "tags": [
    "windows",
    "windows-11",
    "dreamplan",
    "home-design",
    "floor-plan",
    "architecture",
    "3d-modeling",
    "nch-software",
    "desktop"
  ],
  "default_cache_level": "post_start",
  "default_use_savevm": true
}
